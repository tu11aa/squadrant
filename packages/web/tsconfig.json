{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "composite": true,
    "sourceMap": true
  },
  "references": [{ "path": "../core" }, { "path": "../shared" }],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
