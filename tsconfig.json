{
  "references": [{ "path": "packages/shared" }, { "path": "packages/core" }, { "path": "packages/agents" }, { "path": "packages/workspaces" }, { "path": "packages/web" }],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@cockpit/shared": ["./packages/shared/src/index.ts"],
      "@cockpit/core": ["./packages/core/src/index.ts"],
      "@cockpit/agents": ["./packages/agents/src/index.ts"],
      "@cockpit/workspaces": ["./packages/workspaces/src/index.ts"],
      "@cockpit/web": ["./packages/web/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
